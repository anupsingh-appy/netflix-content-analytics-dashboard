      <column caption='Year Added' datatype='date' datatype-customized='true' name='[Calculation_0105422068637703]' role='dimension' type='quantitative'>
        <calculation class='tableau' formula='DATE(DATEPARSE ( &quot;yyyy&quot;, STR(YEAR([date_added])) )) ' />
      </column>
      <column aggregation='Count' caption='Month Added' datatype='date' datatype-customized='true' name='[Calculation_0105422076076042]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='DATE(DATEPARSE ( &quot;MMMM&quot;, DATENAME(&apos;month&apos;,[date_added]) )) ' />
      </column>
      <column caption='Duration Number' datatype='integer' name='[Calculation_0105422076227595]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='INT(SPLIT([duration],&apos; &apos;,1))' />
      </column>
      <column caption='Movie Count' datatype='integer' name='[Calculation_0105422076858380]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [type] = &quot;Movie&quot; THEN 1 END' />
      </column>
      <column caption='TV Shows Count' datatype='integer' name='[Calculation_0105422077587469]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [type] = &quot;TV Show&quot; THEN 1 END' />
      </column>
